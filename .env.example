# Monorepo 환경 변수 예시
# 사용법: 각 패키지에서 복사 후 로컬 .env 로 저장
#   cp .env.example backend/.env   (또는 backend/.env.example 참고)
#   cp frontend/.env.example frontend/.env

# ── Backend (Spring Boot, port 8080) ──
# backend/.env 에 설정

# ── Frontend (Vite, port 5173) ──
# frontend/.env 에 설정
# VITE_SERVER_URL=http://000.00.0.00:8080
# VITE_USE_MOCK=true
